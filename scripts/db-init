#!/usr/bin/env bash
# SQLite の DB ファイルを作り db/schema.sql を適用する(何度でも実行可)
#   scripts/db-init [dbパス]   既定: data/mfg.db
set -euo pipefail
cd "$(dirname "$0")/.."

DB=${1:-data/mfg.db}
mkdir -p "$(dirname "$DB")"
.venv/bin/python - "$DB" <<'EOF'
import pathlib
import sqlite3
import sys

db = sqlite3.connect(sys.argv[1])
db.execute("PRAGMA journal_mode=WAL")
db.executescript(pathlib.Path("db/schema.sql").read_text())
db.close()
print(f"ok: {sys.argv[1]} に db/schema.sql を適用した")
EOF
